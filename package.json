{
  "name": "library-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_DISABLE_WEBPACK_CACHE=1 next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "cross-env PLAYWRIGHT_BASE_URL=https://library-weld-ten.vercel.app playwright test --project=chromium",
    "test:load:smoke": "npm run test:load:smoke:read && npm run test:load:smoke:guards",
    "test:load:smoke:read": "node scripts/run-k6.mjs tests/load/smoke-read.js",
    "test:load:smoke:guards": "node scripts/run-k6.mjs tests/load/smoke-guards.js",
    "test:load:prod:smoke": "cross-env LOAD_BASE_URL=https://library-weld-ten.vercel.app npm run test:load:smoke",
    "metrics:catalog:explain": "node scripts/explain-catalog.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.21.1",
    "@tanstack/react-query": "^5.62.16",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.474.0",
    "next": "^14.2.26",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.26",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "prisma": "^5.21.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
